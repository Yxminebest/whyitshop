# 🛡️ WhyITshop Backend Configuration

# ✅ Supabase Configuration
SUPABASE_URL=https://kslyrllmwbbgcepvotps.supabase.co
SUPABASE_KEY=your_supabase_anon_key_here

# ✅ Security Configuration
SESSION_SECRET=your-super-secret-session-key-change-in-production-min-32-chars
NODE_ENV=development  # Change to "production" for deployment

# ✅ Server Configuration
PORT=5000
API_URL=http://localhost:5000

# ✅ Frontend Configuration (CORS)
FRONTEND_URL=http://localhost:5173
FRONTEND_PRODUCTION_URL=https://whyitshop.vercel.app

# ✅ Email Configuration (for password reset)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASSWORD=your-app-password-not-regular-password

# ✅ Security Limits
RATE_LIMIT_WINDOW_MS=900000  # 15 minutes in ms
RATE_LIMIT_MAX_REQUESTS=5   # Max login attempts
API_RATE_LIMIT_WINDOW_MS=60000  # 1 minute
API_RATE_LIMIT_MAX_REQUESTS=30   # Max API calls per minute

# ✅ Account Lockout Settings
LOCKOUT_DURATION_MINUTES=15
MAX_LOGIN_ATTEMPTS=5

# ✅ JWT Configuration (if using JWT tokens)
JWT_SECRET=your-jwt-secret-key-change-in-production
JWT_EXPIRES_IN=7d
